{
  "name": "droidsmith",
  "main": ".open-next/worker.js",
  "compatibility_date": "2024-09-23",
  "compatibility_flags": ["nodejs_compat"],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "vars": {
    "NEXT_PUBLIC_APP_URL": "https://droidsmith.dev"
  }
  // KV namespace for ISR caching (add binding when live):
  // "kv_namespaces": [
  //   { "binding": "NEXT_CACHE_WORKERS_KV", "id": "<KV_ID>" }
  // ]
}
