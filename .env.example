# Database — Neon
DATABASE_URL=postgresql://...?sslmode=require
DATABASE_URL_UNPOOLED=postgresql://...?sslmode=require

# Auth — Better Auth
BETTER_AUTH_SECRET=                      # openssl rand -base64 32
BETTER_AUTH_URL=http://localhost:3000    # production: https://blacksmith.dev

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000

# AI Generation — Gemini (NEVER prefix with NEXT_PUBLIC_)
GOOGLE_GENERATIVE_AI_API_KEY=AIza...

# Rate Limiting — Upstash Redis
UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=AX...

# Payments — LemonSqueezy
LEMONSQUEEZY_API_KEY=eyJ...
LEMONSQUEEZY_WEBHOOK_SECRET=...
LEMONSQUEEZY_STORE_ID=...
LEMONSQUEEZY_PRO_VARIANT_ID=...

# Free tier limit (default: 5 per month)
FREE_TIER_GENERATION_LIMIT=5
